---

---

<section class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-text">
        We care about developers
      </h2>
      <p class="mt-4 text-text-secondary text-lg max-w-2xl leading-relaxed">
        Use the power of GTA V with our JavaScript and C# APIs. Build custom gamemodes, create unique experiences, and bring your ideas to life with comprehensive developer tools.
      </p>
    </div>

    <!-- Resource cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Documentation -->
      <a
        href="https://docs.altv.mp/"
        class="group bg-surface border border-border rounded-xl p-6 hover:bg-surface-hover transition-colors"
      >
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-6 h-6 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
            <polyline points="10 9 9 9 8 9"></polyline>
          </svg>
          <h3 class="text-lg font-bold text-text">Documentation</h3>
          <svg class="w-5 h-5 text-text-secondary ml-auto group-hover:text-accent group-hover:translate-x-1 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </div>
        <p class="text-text-secondary text-sm leading-relaxed">
          Discover how our API works, access code samples and SDKs, and find step-by-step guides for server development.
        </p>
      </a>

      <!-- Server Manager -->
      <a
        href="https://my.alt-mp.com/"
        class="group bg-surface border border-border rounded-xl p-6 hover:bg-surface-hover transition-colors"
      >
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-6 h-6 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
          </svg>
          <h3 class="text-lg font-bold text-text">Server Manager</h3>
          <svg class="w-5 h-5 text-text-secondary ml-auto group-hover:text-accent group-hover:translate-x-1 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </div>
        <p class="text-text-secondary text-sm leading-relaxed">
          Generate a server token, activate special features, and easily manage various server functions - all from an intuitive dashboard.
        </p>
      </a>

      <!-- GTA NativeDB -->
      <a
        href="https://natives.altv.mp/"
        class="group bg-surface border border-border rounded-xl p-6 hover:bg-surface-hover transition-colors"
      >
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-6 h-6 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
            <line x1="14" y1="4" x2="10" y2="20"></line>
          </svg>
          <h3 class="text-lg font-bold text-text">GTA NativeDB</h3>
          <svg class="w-5 h-5 text-text-secondary ml-auto group-hover:text-accent group-hover:translate-x-1 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </div>
        <p class="text-text-secondary text-sm leading-relaxed">
          Resources like native functions, model names, animations, and other elements can be useful for client scripts.
        </p>
      </a>

      <!-- Resource Hub -->
      <a
        href="https://hub.altv.mp/"
        class="group bg-surface border border-border rounded-xl p-6 hover:bg-surface-hover transition-colors"
      >
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-6 h-6 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
            <line x1="12" y1="22.08" x2="12" y2="12"></line>
          </svg>
          <h3 class="text-lg font-bold text-text">Resource Hub</h3>
          <svg class="w-5 h-5 text-text-secondary ml-auto group-hover:text-accent group-hover:translate-x-1 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </div>
        <p class="text-text-secondary text-sm leading-relaxed">
          Browse community-developed resources. Find useful tools, scripts, or ready-made gamemodes.
        </p>
      </a>
    </div>
  </div>
</section>
