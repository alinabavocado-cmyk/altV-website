---

---

<section class="relative mx-auto border-b border-white/10 px-6 pb-24 pt-20 md:px-10">
  <!-- Background layer (GTA V image with overlays) -->
  <div
    class="pointer-events-none absolute inset-0 -z-[1] saturate-[1.25]"
    style="background: linear-gradient(transparent, rgba(6,6,6,0.4) 70%, rgb(15,15,15)), linear-gradient(rgba(10,10,10,0.7), rgba(10,10,10,0.6)), url('https://altv.mp/img/features_bg_2880x1332.webp'); background-size: cover; background-position: 50% 100%;">
  </div>

  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="text-green-400 text-xs font-semibold tracking-widest uppercase">FEATURES</span>
      <h2 class="mt-4 text-4xl md:text-5xl font-bold text-white">
        Multiplayer Mod, Superpowered
      </h2>
    </div>

    <!-- Feature cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      <!-- Smooth sync -->
      <div
        class="rounded-xl p-6 shadow-lg ring-1 ring-white/15 backdrop-blur-md transition-[transform,box-shadow,background] duration-300 ease-out hover:ring-white/25 hover:[background-position:100%_0%]"
        style="background: linear-gradient(192deg, rgba(255,255,255,0.17) 6.86%, rgba(226,226,226,0.15) 25.71%, rgba(187,187,187,0.18) 49.95%, rgba(200,200,200,0.17) 91.96%); background-size: 100% 250%; background-position: 100% 70%;">
        <div class="mb-4">
          <svg class="w-8 h-8 text-green-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="17 1 21 5 17 9"></polyline>
            <path d="M3 11V9a4 4 0 0 1 4-4h14"></path>
            <polyline points="7 23 3 19 7 15"></polyline>
            <path d="M21 13v2a4 4 0 0 1-4 4H3"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-2">Smooth sync</h3>
        <p class="text-gray-300 text-sm leading-relaxed">
          Enjoy seamless and smooth gameplay even in large multiplayer environments without lag or performance issues.
        </p>
      </div>

      <!-- Easy to use -->
      <div
        class="rounded-xl p-6 shadow-lg ring-1 ring-white/15 backdrop-blur-md transition-[transform,box-shadow,background] duration-300 ease-out hover:ring-white/25 hover:[background-position:100%_0%]"
        style="background: linear-gradient(192deg, rgba(255,255,255,0.17) 6.86%, rgba(226,226,226,0.15) 25.71%, rgba(187,187,187,0.18) 49.95%, rgba(200,200,200,0.17) 91.96%); background-size: 100% 250%; background-position: 100% 70%;">
        <div class="mb-4">
          <svg class="w-8 h-8 text-green-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2l2.09 6.26L20.18 9l-5 4.09L16.64 20 12 16.54 7.36 20l1.46-6.91-5-4.09 6.09-.74z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-2">Easy to use</h3>
        <p class="text-gray-300 text-sm leading-relaxed">
          alt:V is easy to install, takes only a few minutes.
        </p>
      </div>

      <!-- High player count -->
      <div
        class="rounded-xl p-6 shadow-lg ring-1 ring-white/15 backdrop-blur-md transition-[transform,box-shadow,background] duration-300 ease-out hover:ring-white/25 hover:[background-position:100%_0%]"
        style="background: linear-gradient(192deg, rgba(255,255,255,0.17) 6.86%, rgba(226,226,226,0.15) 25.71%, rgba(187,187,187,0.18) 49.95%, rgba(200,200,200,0.17) 91.96%); background-size: 100% 250%; background-position: 100% 70%;">
        <div class="mb-4">
          <svg class="w-8 h-8 text-green-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-2">High player count</h3>
        <p class="text-gray-300 text-sm leading-relaxed">
          Servers can host up to 10,000 players simultaneously, creating an immersive world that truly feels alive.
        </p>
      </div>

      <!-- Integrated voice chat -->
      <div
        class="rounded-xl p-6 shadow-lg ring-1 ring-white/15 backdrop-blur-md transition-[transform,box-shadow,background] duration-300 ease-out hover:ring-white/25 hover:[background-position:100%_0%]"
        style="background: linear-gradient(192deg, rgba(255,255,255,0.17) 6.86%, rgba(226,226,226,0.15) 25.71%, rgba(187,187,187,0.18) 49.95%, rgba(200,200,200,0.17) 91.96%); background-size: 100% 250%; background-position: 100% 70%;">
        <div class="mb-4">
          <svg class="w-8 h-8 text-green-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
            <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
            <line x1="12" y1="19" x2="12" y2="23"></line>
            <line x1="8" y1="23" x2="16" y2="23"></line>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-2">Integrated voice chat</h3>
        <p class="text-gray-300 text-sm leading-relaxed">
          Stay connected with the integrated voice chat and you won't need any third-party software.
        </p>
      </div>
    </div>

    <!-- Bottom text -->
    <p class="text-center text-gray-400 text-sm max-w-2xl mx-auto">
      Want to learn more about alt:V? Check out the official
      <a href="https://docs.altv.mp/" class="text-white underline underline-offset-4 hover:text-green-400 transition-colors">documentation</a>
      for all detailed features.
    </p>
  </div>
</section>
