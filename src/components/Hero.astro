---

---

<section id="hero-section" class="relative mx-auto lg:px-8 lg:pt-36">
  <!-- Background ambient layer (only visible on lg+) -->
  <div
    class="intro-background absolute -left-1/2 -right-1/2 top-0 -z-[1] mx-auto hidden h-full max-w-full object-cover opacity-30 lg:block"
    style="background: linear-gradient(rgba(11,11,11,0.6), rgba(11,11,11,0), rgb(11,11,11)), linear-gradient(90deg, rgb(11,11,11), rgba(11,11,11,0), rgb(11,11,11)), url('https://altv.mp/img/intro_bg_3840x2160.webp'); background-size: 100%;"
  ></div>

  <!-- Main content container with rounded card and background image -->
  <div
    class="intro-overlay mx-auto flex flex-col items-center gap-y-12 border-b border-stone-500 px-6 py-20 lg:container sm:px-8 sm:py-24 lg:rounded-[32px] lg:border-b-0 lg:p-24 lg:px-0 lg:ring-1 lg:ring-white/15 xl:max-w-[1200px]"
    style="background: linear-gradient(rgba(20,20,20,0.5), rgb(11,11,11)), url('https://altv.mp/img/intro_bg_3840x2160.webp'); background-size: 1825px; background-position: 50% 100%;"
  >
    <!-- Content area -->
    <div class="flex w-full max-w-3xl flex-col items-center gap-y-6">
      <!-- Headline -->
      <h1 class="animate-in fade-in-0 slide-in-from-top-3 duration-1000 text-center text-[2rem] font-bold sm:text-5xl lg:text-6xl xl:text-7xl">
        Multiplayer experience is now even better
      </h1>

      <!-- Subtitle -->
      <p class="animate-in fade-in-0 slide-in-from-top-3 delay-300 duration-1000 fill-mode-backwards text-center text-base/relaxed text-stone-400 md:text-lg/relaxed">
        alt:V Multiplayer is a free modification for Grand Theft Auto V, allowing you to play on dedicated servers with custom gamemodes
      </p>

      <!-- Player count badge -->
      <div class="animate-in fade-in-0 slide-in-from-top-3 fill-mode-backwards inline-flex items-center gap-2 rounded-full bg-white/5 px-4 py-2 ring-1 ring-white/10" style="animation-delay: 300ms; animation-duration: 1000ms;">
        <span class="relative flex h-2.5 w-2.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-green-400"></span>
        </span>
        <span class="text-sm text-stone-400">
          <span class="font-semibold text-white">311</span> players on <span class="font-semibold text-white">19</span> servers
        </span>
      </div>
    </div>

    <!-- CTA Buttons area -->
    <div class="delay-500 duration-1000 animate-in fade-in-0 slide-in-from-top-3 fill-mode-backwards flex flex-wrap justify-center gap-x-3 gap-y-2">
      <!-- Primary CTA - Download -->
      <a
        href="#"
        class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold text-black hover:bg-white/90 transition-colors duration-150"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 16L12 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <path d="M8 12L12 16L16 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M4 17V18C4 19.1046 4.89543 20 6 20H18C19.1046 20 20 19.1046 20 18V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        Download alt:V
      </a>

      <!-- Secondary CTA - Browse servers -->
      <a
        href="#"
        class="inline-flex items-center gap-2 rounded-full border border-white/20 px-6 py-3 text-sm font-semibold text-white hover:bg-white/5 transition-colors duration-150"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 5.14v14l11-7-11-7z" fill="currentColor" />
        </svg>
        Browse servers
      </a>
    </div>
  </div>
</section>
